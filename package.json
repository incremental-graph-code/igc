{
	"name": "igc",
	"version": "1.0.0",
    "type": "module",
	"scripts": {
		"install:all": "npm run install:shared && npm run install:frontend && npm run install:backend && npm run install:electron",
		"install:frontend": "cd frontend && npm install",
		"install:backend": "cd backend && npm install",
		"install:electron": "cd electron && npm install",
		"install:shared": "cd shared && npm install",
		"build": "npm run build:shared && npm run build:frontend && npm run build:backend && npm run build:electron",
		"build:frontend": "cd frontend && npm run build",
		"build:backend": "cd backend && npm run build",
		"build:electron": "cd electron && npm run build",
		"build:shared": "cd shared && npm run build",
		"dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
		"dev:frontend": "cd frontend && npm run dev",
		"dev:backend": "cd backend && npm run dev",
		"dist": "cd electron && npm run dist",
		"start": "cd electron && npm run start",
		"lint": "npm run lint:frontend && npm run lint:backend && npm run lint:electron && npm run lint:shared",
		"lint:frontend": "eslint frontend",
        "lint:backend": "eslint backend",
		"lint:electron": "eslint electron",
		"lint:shared": "eslint shared",
		"format": "prettier . --write",
		"test": "npm run test:frontend && npm run test:backend && npm run test:electron && npm run test:shared",
		"test:frontend": "cd frontend && jest",
		"test:backend": "cd backend && jest",
		"test:electron": "cd electron && jest",
		"test:shared": "cd shared && jest",
		"docs": "npm run docs:frontend && npm run docs:backend && npm run docs:electron && npm run docs:shared",
		"docs:frontend": "typedoc --options frontend/typedoc.json",
		"docs:backend": "typedoc --options backend/typedoc.json",
		"docs:electron": "typedoc --options electron/typedoc.json",
		"docs:shared": "typedoc --options shared/typedoc.json",
        "docs:build": "cd docs/website && npm run build",
        "docs:serve": "cd docs/website && npm run start",
		"prepare": "husky install"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/incremental-graph-code/igc.git"
	},
	"author": "Max Boksem",
	"license": "GPL-3.0",
	"description": "Root of IGC",
	"bugs": {
		"url": "https://github.com/incremental-graph-code/igc/issues"
	},
	"homepage": "https://github.com/incremental-graph-code/igc#readme",
	"dependencies": {
		"concurrently": "^9.1.2",
		"dotenv": "^16.5.0",
		"dotenv-cli": "^8.0.0",
		"dotenv-expand": "^12.0.1"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"@typescript-eslint/eslint-plugin": "^8.30.1",
		"@typescript-eslint/parser": "^8.30.1",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.2",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-jsdoc": "^50.6.9",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"husky": "^9.1.7",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"jest-environment-node": "^29.7.0",
		"prettier": "^3.5.3",
		"ts-jest": "^29.3.2",
		"ts-node-dev": "^2.0.0",
		"typedoc": "^0.28.2",
		"typedoc-plugin-markdown": "^4.6.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.30.1",
		"wait-on": "^8.0.3"
	}
}
