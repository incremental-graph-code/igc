{
	"name": "shared",
	"version": "1.0.0",
	"description": "Shared utilities for backend, frontend, and electron",
	"type": "module",
	"main": "./dist/common/index.js",
	"exports": {
		".": {
			"import": "./dist/common/index.js",
			"types": "./dist/common/index.d.ts"
		},
		"./server": {
			"import": "./dist/server/index.js",
			"types": "./dist/server/index.d.ts"
		}
	},
	"typesVersions": {
		"*": {
			"server": [
				"dist/server/index.d.ts"
			],
			"*": [
				"dist/common/index.d.ts"
			]
		}
	},
	"files": [
		"dist/"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx watch src/*.ts",
		"clean": "rm -rf dist *.tsbuildinfo"
	},
	"dependencies": {
		"winston": "^3.17.0"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"jest": "^29.7.0",
		"ts-jest": "^29.3.2",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	}
}
