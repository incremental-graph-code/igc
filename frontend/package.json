{
	"name": "frontend",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "rm -rf dist && tsc && vite build",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"prepare": "husky",
		"generate:zod": "ts-to-zod src/types/convert.ts src/types/convert.zod.ts"
	},
	"author": "Max Boksem",
	"license": "GPL-3.0",
	"description": "Frontend of IGC",
	"dependencies": {
