		"@mui/material": "^7.0.2",
		"@reduxjs/toolkit": "^2.7.0",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/xterm": "^5.5.0",
		"axios": "^1.9.0",
		"copy-to-clipboard": "^3.3.3",
		"fast-deep-equal": "^3.1.3",
		"html-to-image": "^1.11.13",
		"js-cookie": "^3.0.5",
		"lodash": "^4.17.21",
		"path-browserify": "^1.0.1",
