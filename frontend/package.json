		"globals": "^16.0.0",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"tailwindcss": "^4.1.5",
		"ts-to-zod": "^3.15.0",
		"typescript": "^5.8.3",
		"vite": "^6.3.4",
		"zod": "^3.25.3"
