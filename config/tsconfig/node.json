{
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["ES2023"],
        "target": "ES2023",

        
        "module": "ESNext",
        "moduleResolution": "bundler",
		"types": ["jest", "node"],

        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,

        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true
	},
	"include": ["src"]
}
